# Isomo Voice AI - required configuration (names only; real values live in ~/.isomo/voiceai.env)
# Copy to .env and fill in. .env is gitignored.

# --- Supabase (from your Supabase project settings) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # webhook only - server-side, never in frontend

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=           # the one agent's id (from the ElevenLabs dashboard)

# --- Tools wired into the agent (used in ElevenLabs dashboard / webhook) ---
MEM0_API_KEY=
EXA_API_KEY=
