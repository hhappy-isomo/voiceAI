# Dev-only: bypass Google sign-in (skip Supabase auth) so the UI shell
# renders without real creds. Never set in production.
# NEXT_PUBLIC_DEV_BYPASS_AUTH=1
# NEXT_PUBLIC_DEV_BYPASS_ROLE=student   # or "facilitator"

# Server-only — for auto-rubric CEFR scoring via Claude Sonnet 4.6.
# Used by the /api/auto-rubric route. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Server-only — Supabase service_role for the auto-rubric route (writes
# to auto_rubric_scores bypassing RLS).
SUPABASE_SERVICE_ROLE_KEY=ey...
