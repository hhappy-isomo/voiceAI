# Supabase project (existing: buuyfdjpupolvvocdzna)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# ElevenLabs Conversational AI agent id (from the agent's URL/share page)
